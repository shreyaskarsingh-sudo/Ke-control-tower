# ─── GoKwik CSM Control Tower — Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.
# Add .env to .gitignore — never commit real tokens!
#
# Run server with: node server.js  (dotenv is loaded automatically)
# Or with env: SLACK_TOKEN=xoxb-... node server.js

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3000

# CORS: Comma-separated list of allowed origins.
# For localhost dev: leave as *
# For EC2 production: set to your actual domain/IP
# e.g. ALLOWED_ORIGINS=http://123.45.67.89:3000,https://csm.gokwik.co
ALLOWED_ORIGINS=*

# ─── SLACK ───────────────────────────────────────────────────────────────────
# Bot OAuth Token from https://api.slack.com/apps
# Required scopes: chat:write, im:write, im:read, users:read
SLACK_TOKEN=xoxb-YOUR-SLACK-BOT-TOKEN-HERE

# ─── JIRA (Shared config — same for all GoKwik CSMs) ─────────────────────────
# These are set in users.json per-user, but you can set global defaults here.
JIRA_DOMAIN=gokwik.atlassian.net
JIRA_CLOUD_ID=14b846a5-a9a6-423c-a169-78241b8aafc2

# ─── GMAIL (GCP OAuth 2.0) ───────────────────────────────────────────────────
# From your GCP project → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Scopes needed: gmail.readonly, gmail.compose
#
# These can be global fallbacks, or set per-user in users.json.
GMAIL_CLIENT_ID=YOUR_GCP_CLIENT_ID.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=YOUR_GCP_CLIENT_SECRET

# Global refresh token (optional — prefer per-user in users.json for multi-user)
GMAIL_REFRESH_TOKEN=YOUR_GMAIL_REFRESH_TOKEN

# Default "from" address for Gmail drafts (usually your email)
GMAIL_FROM=your.name@gokwik.co

# ─── PERISKOPE (KwikEngage WhatsApp Groups) ───────────────────────────────────
# API key from https://app.periskope.app → Settings → API
PERISKOPE_API_KEY=your_periskope_api_key_here
# The two KwikEngage phone numbers (with country code, no +)
PERISKOPE_PHONE_1=91XXXXXXXXXX
PERISKOPE_PHONE_2=91XXXXXXXXXX

# ─── KE MCP (KwikEngage Internal MCP Server) ─────────────────────────────────
KE_MCP_URL=http://10.8.2.63:3006/mcp
# Admin credentials used server-side to look up merchants by name
KE_ADMIN_EMAIL=your-ke-admin@gokwik.co
KE_ADMIN_TOKEN=your-ke-admin-token
